# TMDB (The Movie Database) API token (Bearer JWT)
# Get yours at https://www.themoviedb.org/settings/api
VITE_TMDB_TOKEN=

# Clerk publishable key (frontend)
# Get yours at https://clerk.com → dashboard → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend API URL (leave empty for development — Vite proxy handles /api)
# In production, set to your Railway/Render URL, e.g. https://cuefilm-api.up.railway.app
VITE_API_URL=

# Sentry DSN for error monitoring (optional)
# Get yours at https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=
