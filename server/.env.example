# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cuefilm
MONGODB_URI=

# Clerk secret key (from Clerk dashboard → API Keys)
CLERK_SECRET_KEY=sk_test_...

# URL to the frontend (used for CORS)
# Dev: http://localhost:5173 | Prod: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

PORT=3001

# OpenRouter API key (for AI explanations — free tier available)
# Get yours at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-...

# Node environment
NODE_ENV=development
